{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "types": ["node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@api/*": ["./api/*"],
      "@shared/*": ["./shared/*"],
      "@testing/*": ["./testing/*"]
    }
  },
  "include": [
    "vite.config.ts",
    "netlify",
    "shared",
    "setup.node.ts",
    "api",
    "testing/node",
    "tests/unit",
    "tests/integration",
    "tests/e2e"
  ]
}
